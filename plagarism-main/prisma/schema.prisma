generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String?
  plan         String   @default("Free Plan")
  trialLimit   Int      @default(3)
  trialsUsed   Int      @default(0)
  createdAt    DateTime @default(now())
  scans        Scan[]
}

model Scan {
  id                  String   @id @default(cuid())
  filename            String
  date                DateTime @default(now())
  similarity          Float
  aiScore             Float
  words               Int
  extractedCharacters Int
  plagiarismResult    Json
  aiResult            Json
  userId              String?
  user                User?    @relation(fields: [userId], references: [id])
}
